---
import Heading from "@shared/components/ui/Heading.astro";
import ContactForm from "@shared/components/ui/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const { lang } = Astro.params;
const staticDataCollection = await getCollection("staticData");
const staticDataEntry =
  staticDataCollection.find((entry) => entry.id === lang) ||
  staticDataCollection.find((entry) => entry.id === "es");
const {
  contactSectionTitle,
  contactSectionSubtitle,

  email,
  contactSectionButtonIcon,
} = staticDataEntry.data;
---

<section id="contact" class="relative overflow-hidden animate-fade-up animate-once animate-duration-1000 animate-delay-300">
  <div
    class="w-full border-t border-b bg-linear-to-b from-mint-50/50 to-white dark:from-zinc-900/50 dark:to-zinc-950 dark:border-zinc-800 border-mint-100"
  >
    <div class="mx-auto max-w-7xl px-8 py-24 max-lg:py-16">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="flex flex-col gap-6 max-w-xl">
          <Heading text={contactSectionTitle} textGradient={contactSectionSubtitle} level={2} />
          <p class="text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">
            I'm always open to discussing new projects, creative ideas or opportunities to be part
            of your visions.
          </p>

          <div class="flex flex-col gap-4 mt-8">
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-4 text-zinc-700 dark:text-zinc-300 hover:text-mint-500 dark:hover:text-mint-400 transition-colors group"
            >
              <div
                class="size-12 rounded-full bg-mint-100 dark:bg-zinc-800 flex items-center justify-center group-hover:bg-mint-200 dark:group-hover:bg-zinc-700 transition-colors"
              >
                <Icon name={contactSectionButtonIcon} class="size-6" />
              </div>
              <span class="text-lg font-medium">{email}</span>
            </a>
          </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <ContactForm />
        </div>
      </div>
    </div>
  </div>
</section>
