---
import { Icon } from "astro-icon/components";
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  class="w-full max-w-lg flex flex-col gap-6 bg-white/50 dark:bg-zinc-900/50 backdrop-blur-md p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 shadow-xl"
>
  <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "YOUR_ACCESS_KEY_HERE"} />
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

  <label class="flex flex-col gap-2">
    <span class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1">Name</span>
    <input
      type="text"
      name="name"
      id="name"
      placeholder="Your Name"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400"
    />
  </label>

  <label class="flex flex-col gap-2">
    <span class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1">Email</span>
    <input
      type="email"
      name="email"
      id="email"
      placeholder="your@email.com"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400"
    />
  </label>

  <label class="flex flex-col gap-2">
    <span class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1">Message</span>
    <textarea
      name="message"
      id="message"
      rows="4"
      placeholder="How can I help you?"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400 resize-none"
    ></textarea>
  </label>

  <div
    class="w-full h-fit from-transparent via-riptide-300 to-transparent dark:from-transparent dark:via-mint-500 dark:to-transparent from-40% to-60% animate-rotate-border bg-conic/[from_var(--border-angle)] p-px hover:shadow-lg hover:shadow-mint-500/30 rounded-full mt-2"
  >
    <button
      type="submit"
      id="submit-btn"
      class="w-full cursor-pointer leading-none hover:scale-[1.02] font-medium flex gap-2 transition-all ease-in-out justify-center items-center rounded-full px-6 py-4 text-lg bg-linear-to-r from-riptide-200 to-mint-200 dark:from-riptide-500 dark:to-mint-500 text-blacktext dark:text-mint-50 dark:hover:text-white disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <Icon name="paperplane" class="size-5" id="btn-icon" />
      <span id="btn-text">Send Message</span>
    </button>
  </div>
  <div id="result" class="text-center text-sm font-medium mt-2"></div>
</form>

<script is:inline>
  const form = document.querySelector('form[action="https://api.web3forms.com/submit"]');
  const result = document.getElementById('result');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);
      
      // Loading state
      submitBtn.disabled = true;
      btnText.innerText = "Sending...";
      result.innerText = "";
      result.classList.remove('text-green-500', 'text-red-500');
      result.classList.add('text-zinc-500');

      fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json',
                  'Accept': 'application/json'
              },
              body: json
          })
          .then(async (response) => {
              let json = await response.json();
              if (response.status == 200) {
                  result.innerText = "Message sent successfully! ✨";
                  result.classList.replace('text-zinc-500', 'text-green-500');
                  form.reset();
              } else {
                  console.log(response);
                  result.innerText = json.message || "Something went wrong.";
                  result.classList.replace('text-zinc-500', 'text-red-500');
              }
          })
          .catch(error => {
              console.log(error);
              result.innerText = "Error connecting to service.";
              result.classList.replace('text-zinc-500', 'text-red-500');
          })
          .then(function() {
              submitBtn.disabled = false;
              btnText.innerText = "Send Message";
              setTimeout(() => {
                  result.innerText = "";
              }, 5000);
          });
    });
  }
</script>
