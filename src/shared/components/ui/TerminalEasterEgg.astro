---
// TerminalEasterEgg.astro
---

<div id="easter-egg-terminal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
  <div class="relative w-full max-w-2xl h-[400px] bg-zinc-950 border border-zinc-800 rounded-lg shadow-2xl flex flex-col overflow-hidden transform scale-95 transition-transform duration-300" id="terminal-window">
    <!-- Terminal Header -->
    <div class="flex items-center justify-between px-4 py-2 bg-zinc-900 border-b border-zinc-800">
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500 cursor-pointer" id="close-terminal"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
      </div>
      <div class="text-xs font-mono text-zinc-400">guest@medalcode: ~</div>
      <div></div>
    </div>
    
    <!-- Terminal Body -->
    <div class="flex-1 p-4 font-mono text-sm overflow-y-auto" id="terminal-output" style="scrollbar-width: thin; scrollbar-color: #3f3f46 transparent;">
      <div class="text-mint-400 mb-2">Welcome to Medalcode OS v1.0.0</div>
      <div class="text-zinc-300 mb-4">Type <span class="text-yellow-400">'help'</span> to see available commands.</div>
    </div>
    
    <!-- Terminal Input -->
    <div class="flex items-center px-4 py-2 bg-zinc-900/50">
      <span class="text-mint-400 mr-2 font-mono">➜</span>
      <span class="text-blue-400 mr-2 font-mono">~</span>
      <input 
        type="text" 
        id="terminal-input" 
        class="flex-1 bg-transparent border-none outline-none text-zinc-100 font-mono" 
        autocomplete="off" 
        spellcheck="false"
        autofocus
      />
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const terminal = document.getElementById('easter-egg-terminal');
    const terminalWindow = document.getElementById('terminal-window');
    const closeBtn = document.getElementById('close-terminal');
    const input = document.getElementById('terminal-input');
    const output = document.getElementById('terminal-output');
    
    let isOpen = false;

    const toggleTerminal = () => {
      isOpen = !isOpen;
      if (isOpen) {
        terminal.classList.remove('hidden');
        // trigger reflow
        void terminal.offsetWidth;
        terminal.classList.remove('opacity-0');
        terminalWindow.classList.remove('scale-95');
        setTimeout(() => input.focus(), 100);
      } else {
        terminal.classList.add('opacity-0');
        terminalWindow.classList.add('scale-95');
        setTimeout(() => {
          terminal.classList.add('hidden');
        }, 300);
      }
    };

    // Listen for Ctrl + \ or Cmd + \
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === '\\') {
        e.preventDefault();
        toggleTerminal();
      }
      
      // Close on Escape
      if (e.key === 'Escape' && isOpen) {
        toggleTerminal();
      }
    });

    closeBtn.addEventListener('click', toggleTerminal);
    terminal.addEventListener('click', (e) => {
      if (e.target === terminal) toggleTerminal();
    });

    const commands = {
      help: `Available commands:
  <span class="text-yellow-400">help</span>    - Show this message
  <span class="text-yellow-400">whoami</span>  - About me
  <span class="text-yellow-400">skills</span>  - List my core technologies
  <span class="text-yellow-400">contact</span> - How to reach me
  <span class="text-yellow-400">clear</span>   - Clear the terminal`,
      
      whoami: `I am a Software Developer focused on building high-performance, accessible, and beautiful web applications.`,
      
      skills: `<span class="text-mint-400">Frontend:</span> Astro, Preact, TailwindCSS, TypeScript
<span class="text-blue-400">Backend:</span> Node.js, Python, PostgreSQL, Redis
<span class="text-purple-400">DevOps:</span> Linux, Docker, Git`,
      
      contact: `You can reach me via email or LinkedIn. Try clicking the buttons on the main page!`
    };

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const cmd = input.value.trim().toLowerCase();
        input.value = '';
        
        if (cmd) {
          // Echo command
          output.innerHTML += \`<div class="mt-2"><span class="text-mint-400">➜</span> <span class="text-blue-400">~</span> <span class="text-zinc-100">\${cmd}</span></div>\`;
          
          if (cmd === 'clear') {
            output.innerHTML = '';
          } else if (commands[cmd]) {
            output.innerHTML += \`<div class="text-zinc-300 whitespace-pre-wrap mt-1">\${commands[cmd]}</div>\`;
          } else {
            output.innerHTML += \`<div class="text-red-400 mt-1">Command not found: \${cmd}. Type 'help' for available commands.</div>\`;
          }
          
          output.scrollTop = output.scrollHeight;
        }
      }
    });
  });
</script>
