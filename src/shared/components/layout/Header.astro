---
import Navigation from "./Navigation.astro";
import ThemeIcon from "../ui/ThemeIcon.astro";
import Social from "../ui/Social.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import LanguagePicker from "../ui/LanguagePicker.astro";
import Search from "../ui/Search.astro";
const { lang } = Astro.params;
const currentLang = lang || "es";

const staticDataCollection = await getCollection("staticData");
const staticDataEntry = staticDataCollection.find((entry) => entry.id === currentLang) || staticDataCollection[0];
const { github, githubIconName, linkedin, linkedinIconName } = staticDataEntry?.data || {};

const currentPath = Astro.url.pathname;
// Adjust logic for active route checking if needed, dealing with /es/ or /en/ prefix
const cleanPath = currentPath.replace(`/${lang}`, "") || "/";

const isActiveRoute = ["/", "/portfolio", "/about-me"].includes(cleanPath);

const navItems = isActiveRoute ? ["home", "experience", "projects", "blog", "about"] : ["home", "blog", "about"];
---

<header
  role="banner"
  aria-label="Main navigation"
  class="sticky top-0 z-50 w-full p-4 font-medium text-blacktext dark:text-zinc-300 dark:bg-[#0E0E11]/80 dark:border-b dark:border-zinc-800 bg-white/90 backdrop-blur-xs dark:backdrop-blur-xs max-md:z-50 max-md:px-0 transition-all"
>
  <div class="relative mx-auto flex max-w-7xl flex-row items-center justify-between max-xl:px-6">
    <a href={`/${lang}/`} aria-label="Go to home">
      <span
        class="text-2xl font-bold cursor-pointer transition-all hover:text-mint-300 tracking-tighter"
      >
        MEDALCODE
      </span>
    </a>

    <Navigation items={navItems} />

    <div class="flex items-center justify-between gap-5 text-xl">
      <div class="max-md:hidden flex items-center justify-center gap-5" role="group">
        <Social link={github} iconName={githubIconName} />
        <Social link={linkedin} iconName={linkedinIconName} />
      </div>

      <LanguagePicker />
      <Search />
    </div>
    <div class="flex items-center gap-5 text-xl md:pl-5">
      <ThemeIcon />
      <button
        class="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="bars" class="hamburger-icon bars-icon" aria-hidden="true" />
        <Icon name="xmark" class="hamburger-icon xmark-icon" aria-hidden="true" />
      </button>
    </div>
  </div>
</header>
