---
import { Icon } from "astro-icon/components";

const { lang = "es" } = Astro.params;

const otherLang = lang === "es" ? "en" : "es";
const label = lang === "es" ? "EN" : "ES";
const currentPath = Astro.url.pathname;
const currentPathWithoutLang = currentPath.replace(/^\/(es|en)/, "");
const switchUrl = `/${otherLang}${currentPathWithoutLang}`;
---

<a
  href={switchUrl}
  class="group relative flex items-center justify-center p-2 rounded-full hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all duration-300"
  aria-label={`Switch to ${otherLang === "es" ? "Spanish" : "English"}`}
>
  <div
    class="flex items-center gap-2 font-bold text-sm text-blacktext dark:text-zinc-300 group-hover:text-mint-500 dark:group-hover:text-mint-400"
  >
    <Icon name="language" class="size-5" />
    <span>{label}</span>
  </div>
</a>
