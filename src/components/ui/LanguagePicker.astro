---
import { Icon } from "astro-icon/components";

const { lang = "es" } = Astro.params;

const currentPath = Astro.url.pathname;
const currentPathWithoutLang = currentPath.replace(/^\/(es|en)/, "");

const esUrl = `/es${currentPathWithoutLang}`;
const enUrl = `/en${currentPathWithoutLang}`;
---

<div class="flex items-center gap-1 bg-zinc-100 dark:bg-zinc-800/50 rounded-full p-1 border border-zinc-200 dark:border-zinc-700/50">
  <a
    href={esUrl}
    class={`px-3 py-1 rounded-full text-xs font-bold transition-all duration-300 ${
      lang === "es"
        ? "bg-white dark:bg-zinc-700 text-mint-600 dark:text-mint-400 shadow-sm"
        : "text-zinc-500 dark:text-zinc-400 hover:text-blacktext dark:hover:text-zinc-200"
    }`}
    aria-label="Cambiar a Español"
  >
    ES
  </a>
  <a
    href={enUrl}
    class={`px-3 py-1 rounded-full text-xs font-bold transition-all duration-300 ${
      lang === "en"
        ? "bg-white dark:bg-zinc-700 text-mint-600 dark:text-mint-400 shadow-sm"
        : "text-zinc-500 dark:text-zinc-400 hover:text-blacktext dark:hover:text-zinc-200"
    }`}
    aria-label="Switch to English"
  >
    EN
  </a>
</div>
