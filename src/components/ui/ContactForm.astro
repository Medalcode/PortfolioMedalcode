---
import { Icon } from "astro-icon/components";
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  class="w-full max-w-lg flex flex-col gap-6 bg-white/50 dark:bg-zinc-900/50 backdrop-blur-md p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 shadow-xl"
>
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
  <!-- Replace with your actual Web3Forms Access Key -->

  <div class="flex flex-col gap-2">
    <label for="name" class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1"
      >Name</label
    >
    <input
      type="text"
      name="name"
      id="name"
      placeholder="Your Name"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="email" class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1"
      >Email</label
    >
    <input
      type="email"
      name="email"
      id="email"
      placeholder="your@email.com"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="message" class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 ml-1"
      >Message</label
    >
    <textarea
      name="message"
      id="message"
      rows="4"
      placeholder="How can I help you?"
      required
      class="w-full px-5 py-3 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-black/40 focus:ring-2 focus:ring-mint-500 focus:border-mint-500 outline-none transition-all text-zinc-800 dark:text-zinc-100 placeholder-zinc-400 resize-none"
    ></textarea>
  </div>

  <div
    class="w-full h-fit from-transparent via-riptide-300 to-transparent dark:from-transparent dark:via-mint-500 dark:to-transparent from-40% to-60% animate-rotate-border bg-conic/[from_var(--border-angle)] p-px hover:shadow-lg hover:shadow-mint-500/30 rounded-full mt-2"
  >
    <button
      type="submit"
      class="w-full cursor-pointer leading-none hover:scale-[1.02] font-medium flex gap-2 transition-all ease-in-out justify-center items-center rounded-full px-6 py-4 text-lg bg-linear-to-r from-riptide-200 to-mint-200 dark:from-riptide-500 dark:to-mint-500 text-blacktext dark:text-mint-50 dark:hover:text-white"
    >
      <Icon name="paperplane" class="size-5" />
      Send Message
    </button>
  </div>
</form>
