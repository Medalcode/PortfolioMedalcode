---
interface Props {
  title: string;
  company: string;
  description: string;
  link?: string;
  date: string;
}

const { title, company, description, date } = Astro.props;
---

<div class="relative mx-12 pb-12 grid md:grid-cols-5 md:gap-10 group">
  <!-- Timeline Line (handled by parent or pseudo-element, but here we enforce local styling for item) -->
  <div class="absolute left-[-36px] top-0 h-full w-[2px] bg-zinc-200 dark:bg-zinc-800"></div>

  <!-- Timeline Dot -->
  <div
    class="absolute -left-[44px] top-1 size-5 rounded-full bg-gradient-to-br from-mint-400 to-mint-600 border-4 border-white dark:border-zinc-900 shadow-[0_0_10px_rgba(45,212,191,0.5)] z-10 transition-transform duration-300 group-hover:scale-125"
  >
  </div>

  <div class="pb-12 md:col-span-2">
    <div class="sticky top-24 flex flex-col gap-1">
      <h3 class="text-xl font-bold text-mint-500 dark:text-mint-400 leading-tight">
        {title}
      </h3>
      <h4 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
        {company}
      </h4>
      <time
        class="text-sm font-medium text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-3 py-1 rounded-full w-fit mt-2"
      >
        {date}
      </time>
    </div>
  </div>

  <div
    class="relative flex flex-col gap-4 pb-4 text-zinc-600 dark:text-zinc-300 md:col-span-3 text-lg leading-relaxed bg-zinc-50/50 dark:bg-zinc-800/30 p-6 rounded-2xl border border-zinc-100 dark:border-zinc-800/50 hover:border-mint-200 dark:hover:border-mint-900 transition-colors"
  >
    <p>{description}</p>
  </div>
</div>
