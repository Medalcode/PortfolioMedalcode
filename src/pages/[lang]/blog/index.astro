---
import Layout from "@/layouts/Layout.astro";
import Hero from "@features/blog/components/Hero.astro";
import Tags from "@features/blog/components/Tags.astro";
import ListPosts from "@features/blog/components/ListPosts.astro";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const pageTitle = "Web Development and Technology Blog | Fernando López | EFEELE";
const description =
  "Welcome to my blog, where I share my passion for frontend development, web design, and the latest technology trends.";
const ogimage = {
  url: "/images/blogimage.webp",
  alt: "EFEELE.dev logo with green background and light effect. Text: 'Web Development and Technology Blog' and URL 'www.efeele.dev'.",
};
---

<Layout pageTitle={pageTitle} description={description} ogimage={ogimage}>
  <Hero />
  <Tags />
  <div class="px-8 max-sm:px-4">
    <ListPosts />
  </div>
</Layout>
