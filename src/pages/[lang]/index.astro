---
import Layout from "@/layouts/Layout.astro";
import Experience from "@features/portfolio/components/Experience.astro";
import HeroIndex from "@features/portfolio/components/HeroIndex.astro";
import Contact from "@features/portfolio/components/Contact.astro";
import ListProjects from "@features/portfolio/components/ListProjects.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;

const staticDataCollection = await getCollection("staticData");
const staticDataEntry = staticDataCollection.find((entry) => entry.id === lang);
const { pageTitle, pageDescription, OGImage } = staticDataEntry.data;
---

<Layout
  pageTitle={pageTitle}
  description={pageDescription}
  ogimage={{ alt: OGImage.alt, url: OGImage.url }}
>
  <HeroIndex />
  <Experience />
  <ListProjects />
  <Contact />
</Layout>
