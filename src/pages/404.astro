---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

// Detect preferred language from URL or fallback to 'es'
const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";

const staticDataCollection = await getCollection("staticData");
const staticDataEntry = staticDataCollection.find((entry) => entry.id === lang) || staticDataCollection.find((entry) => entry.id === "es");

const translations = {
  es: {
    title: "Página no encontrada",
    description: "Lo sentimos, la página que buscas no existe o ha sido movida.",
    button: "Volver al inicio",
  },
  en: {
    title: "Page Not Found",
    description: "Sorry, the page you are looking for does not exist or has been moved.",
    button: "Back to Home",
  }
}

const t = translations[lang];
---

<Layout pageTitle={`404 - ${t.title}`} description={t.description}>
  <section class="flex flex-col items-center justify-center min-h-[70vh] text-center px-4">
    <div class="animate-fade-up animate-once animate-duration-1000">
        <Icon name="error-404" class="text-9xl text-mint-500 mb-6 mx-auto opacity-80" />
        <h1 class="text-6xl font-black text-blacktext dark:text-white mb-4">404</h1>
        <h2 class="text-2xl font-bold text-mint-600 dark:text-mint-400 mb-6">{t.title}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-md mx-auto mb-10">
        {t.description}
        </p>
        <Button link={`/${lang}`} text={t.button} />
    </div>
  </section>
</Layout>
